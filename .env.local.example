# Local Docker MongoDB connection (inside compose network)
MONGODB_URI=mongodb://mongo:27017/mongo_showcase
POSTGRES_URI=postgresql://showcase:showcase_password@postgres:5432/showcase_db
POSTGRES_USER=showcase
POSTGRES_PASSWORD=showcase_password
POSTGRES_DB=showcase_db

# Optional backend settings
MONGODB_DB_NAME=mongo_showcase
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*
SEED_ON_START=false

# Frontend build-time API URL for Docker image
VITE_API_BASE_URL=http://localhost:3000/api/v1
