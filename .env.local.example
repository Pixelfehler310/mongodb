# Local Docker MongoDB connection (inside compose network)
MONGODB_URI=mongodb://mongo:27017/mongo_showcase

# Optional backend settings
MONGODB_DB_NAME=mongo_showcase
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*
SEED_ON_START=false

# Frontend build-time API URL for Docker image
VITE_API_BASE_URL=http://localhost:3000/api/v1
